<% content_for(:title, t('.title')) %>
<div class="flex flex-col">
  <div class="border-b-2 text-center mx-2">
    <h2 class="text-3xl"><%= t('.title') %></h2>
  </div>
  <div class="flex flex-col text-center">
    <% if @incidents.present? %>
      <%= render @incidents %>
    <% else %>
      事件記録はありません
    <% end %>
  </div>
  <div class="flex justify-center mb-3">
    <%= paginate @incidents %>
  </div>
  <div class="flex justify-center">
    <%= link_to "新規作成", new_incident_path, class: "flex border-2 rounded-xl h-10 w-30 items-center justify-center" %>
  </div>
</div>