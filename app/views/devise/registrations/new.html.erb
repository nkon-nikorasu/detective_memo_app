<div class="text-center divide-y divide-dashed">
  <h2 class="text-3xl"><%= t('.sign_up') %></h2>

  <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "flex flex-col justify-end gap-5 mb-2" }) do |f| %>
    <%= render "devise/shared/error_messages", resource: resource %>

    <div class="field">
      <p><%= f.label :email %></p>
      <p><%= f.email_field :email, autofocus: true, autocomplete: "email", class: "border-2 border-slate-900 rounded " %></p>
    </div>

    <div class="field">
      <p><%= f.label :password %></p>
      <% if @minimum_password_length %>
        <p><em><%= t('devise.shared.minimum_password_length', count: @minimum_password_length) %></em></p>
      <% end %>
      <p><%= f.password_field :password, autocomplete: "new-password", class: "border-2 border-slate-900 rounded" %></p>
    </div>

    <div class="field ">
      <p><%= f.label :password_confirmation %></p>
      <p><%= f.password_field :password_confirmation, autocomplete: "new-password", class: "border-2 border-slate-900 rounded" %></p>
    </div>

    <div class="actions mb-3">
      <%= f.submit t('.sign_up') %>
    </div>
  <% end %>

  <%= render "devise/shared/links" %>
</div>
